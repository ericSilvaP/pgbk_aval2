# Runtime mode for the Express API.
NODE_ENV=development

# HTTP port used by npm run dev / npm start.
PORT=3000

# Matches the PostgreSQL service exposed by docker-compose.yml on localhost:5434.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/trip_requests_db

# Production holidays provider base URL. Automated tests inject fakes instead.
HOLIDAYS_API_BASE_URL=https://brasilapi.com.br
