generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripRequestStatus {
  pending
  canceled
}

model TripRequest {
  id             String            @id @default(uuid())
  requesterName  String            @map("requester_name")
  origin         String
  destination    String
  departureAt    DateTime          @map("departure_at")
  returnAt       DateTime          @map("return_at")
  purpose        String
  passengerCount Int               @map("passenger_count")
  status         TripRequestStatus @default(pending)
  createdAt      DateTime          @default(now()) @map("created_at")

  @@map("trip_requests")
}

model Holiday {
  id      String   @id @default(uuid())
  date    String
  name    String
  type    String
  weekday String?
  year    Int

  @@unique([date, name])
  @@map("holidays")
}

model HolidaySyncConfig {
  year         Int      @id
  lastSyncedAt DateTime @map("last_synced_at")

  @@map("holiday_sync_configs")
}